# Скопируй в .env и подставь свои значения.
# Токен: только от @BotFather (формат 123456789:ABC...)

TELEGRAM_BOT_TOKEN=

# Чат оператора или группа (число, например -1001234567890 для супергруппы).
# Если пусто — бот всё равно отвечает пользователю, но не пересылает оператору.
SUPPORT_OPERATOR_CHAT_ID=

# Для отладки: логировать каждое входящее обновление в консоль (1 = да)
# SUPPORT_BOT_DEBUG=1
